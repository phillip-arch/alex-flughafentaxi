# ===== Supabase (required) =====
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...           # server-only, never expose

# ===== App URLs =====
APP_URL=https://your-app.vercel.app        # server-side canonical (emails, confirm links)
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app
PUBLIC_APP_URL=
PUBLIC_WEB_URL=https://flughafentaxi-servus.at   # static marketing site
PUBLIC_DISPATCH_URL=
APP_SURFACE=                               # set to "app" only for the mobile-shell deployment
APP_ENV=                                   # optional: "preview" forces iframe-safe cookies

# ===== Email (Resend) =====
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=buchung@yourdomain.at    # verified domain in Resend
BOOKING_ALERT_EMAIL=office@yourdomain.at   # gets new-cancellation alerts
ADMIN_LOGIN_ALERT_EMAIL=office@yourdomain.at

# ===== Google Maps =====
GOOGLE_MAPS_API_KEY=AIza...                # server (geocoding/distance)
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=AIza...    # client (Places autocomplete) - restrict by HTTP referrer!

# ===== Flight tracking =====
AERODATABOX_API_KEY=

# ===== Cron =====
CRON_SECRET=generate-a-long-random-string  # Vercel sends it as Bearer token to /api/cron/reminders

# ===== Booking rate limits (optional overrides) =====
BOOKING_RATE_LIMIT_WINDOW_MINUTES=
BOOKING_RATE_LIMIT_IP_MAX=
BOOKING_RATE_LIMIT_EMAIL_MAX=
